#!/usr/bin/env node

/**
 * AGILE CLI Executable
 * 
 * This uses tsx to run the TypeScript CLI directly.
 * For production, compile to JavaScript first.
 */

import("tsx/cli").then(({ run }) => {
  run(["./src/cli.ts", ...process.argv.slice(2)]);
}).catch(() => {
  console.error("Failed to start AGILE CLI via tsx. Make sure dependencies are installed.");
  process.exit(1);
});
