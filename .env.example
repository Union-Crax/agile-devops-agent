# OpenAI API Key (required)
OPENAI_API_KEY=your-api-key-here

# Optional: set model directly (can be model id or alias)
# AGILE_MODEL=gpt-4o-mini

# Optional: select a named profile instead of AGILE_MODEL
# AGILE_MODEL_PROFILE=prod

# Model precedence:
# --model > --profile > AGILE_MODEL > AGILE_MODEL_PROFILE > saved defaults > fallback
