{
  "name": "agile-devops-agent",
  "version": "1.0.6",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Union-Crax/agile-devops-agent.git"
  },
  "description": "Multi-step DevOps Agent powered by OpenAI - Analyze, Deploy, Monitor, Fix",
  "private": false,
  "type": "module",
  "files": [
    "dist/cli",
    ".env.example",
    "README.md",
    "LICENSE"
  ],
  "bin": {
    "agile": "./dist/cli/cli.js"
  },
  "main": "./dist/cli/index.js",
  "scripts": {
    "dev": "tsx src/cli.ts",
    "build": "npm run build:cli",
    "build:cli": "tsup src/cli.ts src/index.ts --format esm --out-dir dist/cli --clean --tsconfig tsconfig.cli.json",
    "start": "node dist/cli/cli.js",
    "agile": "tsx src/cli.ts",
    "agile:analyze": "tsx src/cli.ts analyze",
    "agile:deploy": "tsx src/cli.ts deploy",
    "agile:interactive": "tsx src/cli.ts interactive",
    "test": "tsx --test src/agent/usage.test.ts",
    "typecheck": "npm run typecheck:cli",
    "typecheck:cli": "tsc --project tsconfig.cli.json --noEmit",
    "pack": "npm pack",
    "prepack": "npm run build:cli"
  },
  "keywords": [
    "devops",
    "ai",
    "agent",
    "openai",
    "cli",
    "deployment",
    "automation"
  ],
  "author": "UnionCrax",
  "license": "MIT",
  "dependencies": {
    "agile-devops-agent": "^1.0.6",
    "chalk": "^5.6.2",
    "commander": "^14.0.3",
    "dotenv": "^17.4.2",
    "glob": "^13.0.6",
    "openai": "^6.35.0",
    "ora": "^9.4.0"
  },
  "devDependencies": {
    "@types/node": "^22",
    "tsup": "^8.5.1",
    "tsx": "^4.21.0",
    "typescript": "5.7.3"
  }
}
